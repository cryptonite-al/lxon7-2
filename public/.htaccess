# SPA fallback for Hostinger (Apache) shared hosting.
# This client-side single-page app has no server runtime: every route is
# rendered in the browser by TanStack Router. Requests for real files
# (JS/CSS/images/videos) are served as-is; any other path is rewritten to
# index.html so deep links like /apply work on refresh instead of 404-ing.
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Serve existing files and directories directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  # Pretty admin login URL → the PHP dashboard login (kept out of the SPA).
  RewriteRule ^secureaccess/?$ admin/login.php [L]
  # Everything else falls back to the SPA entry point.
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Build output is fingerprinted by Vite (index-a1b2c3.js), so the filename
  # changes whenever the contents change — safe to cache forever.
  <FilesMatch "\.(js|css|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images and video keep STABLE filenames (derrick.jpg, posters, backdrops,
  # trailers), so they must NOT be immutable — otherwise replacing a file on the
  # server never reaches visitors who already cached it. Short cache + revalidate
  # keeps things fast while letting replacements show up.
  <FilesMatch "\.(png|jpe?g|gif|svg|webp|ico|mp4|webm)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>

  # HTML always fresh so deploys show up immediately.
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
